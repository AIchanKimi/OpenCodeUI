{
	auto_https off
}

# ---- 主入口 :6658 — OpenCode 应用 ----
:6658 {
	route {
		# 目录归档下载（独立文件服务）
		@file_content_write {
			method PUT
			path /api/file/content /api/file/content*
		}
		handle @file_content_write {
			request_body {
				max_size 1MB
			}
			uri strip_prefix /api
			reverse_proxy opencode-file-service:4097 {
				flush_interval -1
			}
		}

		@file_content_read {
			method GET
			path /api/file/content /api/file/content*
		}
		handle @file_content_read {
			uri strip_prefix /api
			reverse_proxy opencode-file-service:4097 {
				flush_interval -1
			}
		}

		@file_health {
			method GET
			path /api/file/health /api/file/health*
		}
		handle @file_health {
			uri strip_prefix /api/file
			reverse_proxy opencode-file-service:4097 {
				flush_interval -1
			}
		}

		@file_download path /api/file/download /api/file/download*
		handle @file_download {
			uri strip_prefix /api
			reverse_proxy opencode-file-service:4097 {
				flush_interval -1
			}
		}

		@file_archive path /api/file/archive /api/file/archive*
		handle @file_archive {
			uri strip_prefix /api
			reverse_proxy opencode-file-service:4097 {
				flush_interval -1
			}
		}

		# API（SSE + WebSocket 自动处理）
		handle_path /api/* {
			reverse_proxy opencode-backend:4096 {
				flush_interval -1
			}
		}

		# Routes UI + Preview API（供面板切换预览端口）
		@router path /routes /preview/*
		handle @router {
			reverse_proxy 127.0.0.1:7070
		}

		# 前端（兜底）
		handle {
			reverse_proxy opencode-frontend:3000
		}
	}
}

# ---- 开发服务入口 :6659 — 绑独立域名 ----
# 路径穿透 /p/{token}/ + 独占预览（兜底）
:6659 {
	# 动态端口路由（由 router 自动生成）
	import /etc/caddy/routes.conf

	# 独占预览（兜底：未匹配路径穿透的请求走 preview 端口）
	handle {
		import /etc/caddy/preview.conf
	}
}
